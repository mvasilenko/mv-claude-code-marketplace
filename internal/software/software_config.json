{
  "version": "1.0",
  "software": [
    {
      "id": "claude",
      "displayName": "Claude Code CLI",
      "description": "Anthropic's CLI for Claude Code",
      "binaryName": "claude",
      "binaryNameWindows": "claude.exe",
      "category": "required",
      "priority": 1,
      "verifyCommand": "claude --version",
      "installMethods": [
        {
          "type": "homebrew",
          "package": "anthropics/tap/claude-code",
          "platforms": ["darwin"]
        },
        {
          "type": "installer_script",
          "urlUnix": "https://storage.googleapis.com/anthropic-sdk/claude-code/install.sh",
          "urlWindows": "https://storage.googleapis.com/anthropic-sdk/claude-code/install.ps1",
          "platforms": ["darwin", "linux", "windows"]
        }
      ]
    },
    {
      "id": "gh",
      "displayName": "GitHub CLI",
      "description": "GitHub's official command line tool",
      "binaryName": "gh",
      "binaryNameWindows": "gh.exe",
      "category": "required",
      "priority": 2,
      "verifyCommand": "gh --version",
      "installMethods": [
        {
          "type": "homebrew",
          "package": "gh",
          "platforms": ["darwin", "linux"]
        },
        {
          "type": "github_release",
          "repo": "cli/cli",
          "assetPattern": "gh_{version}_{os}_{arch}",
          "platforms": ["darwin", "linux", "windows"]
        }
      ]
    }
  ]
}
